{
    "name": "@blendsdk/lockstep",
    "version": "1.1.0",
    "description": "A comprehensive monorepo package management tool that maintains synchronized versions across all packages (lockstep versioning) with flexible CI/CD integration.",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "bin": {
        "lockstep": "dist/cli.js"
    },
    "files": [
        "dist",
        "bin",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "build": "tsc",
        "build:watch": "tsc --watch",
        "dev": "tsx src/cli.ts",
        "test": "vitest run",
        "test:watch": "vitest --watch",
        "test:coverage": "vitest --coverage",
        "type-check": "tsc --noEmit",
        "clean": "rm -rf dist",
        "prepublishOnly": "npm run clean && npm run build && npm test",
        "release": "npm run prepublishOnly && npm publish",
        "ncu": "ncu -u && rm -fR node_modules package-lock.json && npm install && npm run build"
    },
    "keywords": [
        "monorepo",
        "versioning",
        "lockstep",
        "release",
        "publishing",
        "ci-cd",
        "conventional-commits",
        "semantic-versioning",
        "npm",
        "yarn",
        "pnpm",
        "typescript"
    ],
    "author": "TrueSoftware B.V. <info@truesoftware.nl>",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/TrueSoftwareNL/lockstep.git"
    },
    "bugs": {
        "url": "https://github.com/TrueSoftwareNL/lockstep/issues"
    },
    "homepage": "https://github.com/TrueSoftwareNL/lockstep#readme",
    "devDependencies": {
        "@types/node": "^26.1.1",
        "@vitest/coverage-v8": "^4.1.10",
        "tsx": "^4.23.0",
        "typescript": "^7.0.2",
        "vitest": "^4.1.10"
    },
    "publishConfig": {
        "access": "public"
    },
    "packageManager": "npm@12.0.1",
    "dependencies": {
        "npm-check-updates": "^22.2.9"
    },
    "optionalDependencies": {
        "openai": "^6.46.0",
        "@anthropic-ai/sdk": "^0.111.0"
    }
}
